{
  "name": "notelab",
  "version": "0.0.2",
  "private": true,
  "license": "MIT",
  "dependencies": {
    "expo-router": "~56.2.8"
  },
  "overrides": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @notelab/web",
    "build": "npm run build --workspace @notelab/web",
    "dev:web": "npm run dev --workspace @notelab/web",
    "build:web": "npm run build --workspace @notelab/web",
    "test:web": "npm run test --workspace @notelab/web",
    "dev:desktop": "npm run dev --workspace @notelab/desktop",
    "build:desktop": "npm run build --workspace @notelab/desktop",
    "dev:server": "npm run dev --workspace @notelab/server",
    "build:server": "npm run build --workspace @notelab/server",
    "release": "node scripts/release.mjs",
    "version:set": "node scripts/set-version.mjs"
  }
}
