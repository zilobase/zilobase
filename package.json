{
  "name": "zilobase",
  "version": "0.0.5",
  "private": true,
  "license": "MIT",
  "dependencies": {
    "expo-router": "~56.2.8"
  },
  "overrides": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "workspaces": [
    "apps/*",
    "packages/core-ports",
    "packages/features",
    "packages/license",
    "packages/markdown-text-splitter",
    "packages/page-context",
    "packages/registry",
    "packages/tiptap-comment-extension"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @zilobase/web",
    "build": "npm run build --workspace @zilobase/web",
    "dev:web": "npm run dev --workspace @zilobase/web",
    "build:web": "npm run build --workspace @zilobase/web",
    "test:web": "npm run test --workspace @zilobase/web",
    "dev:desktop": "npm run dev --workspace @zilobase/desktop",
    "build:desktop": "npm run build --workspace @zilobase/desktop",
    "dev:server": "npm run dev --workspace @zilobase/server",
    "build:server": "npm run build --workspace @zilobase/server",
    "db:migrate": "npm run db:migrate --workspace @zilobase/server",
    "release": "node scripts/release.mjs",
    "version:set": "node scripts/set-version.mjs"
  }
}
