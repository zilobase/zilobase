{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "ignoreDeprecations": "5.0",
"paths": {
      "@/*": ["./src/*"],
      "@/packages/editor": ["./src/editor/index.ts"],
      "@/packages/editor/*": ["./src/editor/*"],
      "@zilobase/features/databases/property-types": [
        "./../../packages/features/src/databases/property-types.ts"
      ],
      "@zilobase/features": ["./../../packages/features/src/index.ts"],
      "@zilobase/features/*": ["./../../packages/features/src/*/index.ts"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }],
}
