{
  "name": "@notelab/server",
  "version": "0.0.3",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/adapter-api.ts",
      "default": "./src/adapter-api.ts"
    },
    "./adapter-api": {
      "types": "./src/adapter-api.ts",
      "default": "./src/adapter-api.ts"
    }
  },
  "scripts": {
    "dev": "tsx src/serverful.ts",
    "dev:node": "tsx src/serverful.ts",
    "build": "tsc --noEmit",
    "build:node": "tsc --noEmit",
    "test:insert-database-block": "tsx --test src/services/insert-database-block.test.ts",
    "test:database-property-config": "tsx --test src/services/database-property-config.test.ts",
    "test:database-delta": "tsx --test src/services/database-delta.test.ts",
    "test:databases": "tsx --test src/services/database-property-config.test.ts src/services/database-delta.test.ts src/services/insert-database-block.test.ts",
    "test:collaboration": "tsx --test src/collaboration/*.test.ts",
    "test": "tsx --test 'src/**/*.test.ts' 'src/*.test.ts'",
    "test:api-keys": "tsx src/scripts/test-api-key-flow.ts",
    "test:flow": "tsx src/scripts/simulate-user-flow.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "tsx src/scripts/reset-database.ts && drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.72",
    "@aws-sdk/client-s3": "^3.1070.0",
    "@aws-sdk/s3-request-presigner": "^3.1070.0",
    "@better-auth/api-key": "^1.6.14",
    "@better-auth/drizzle-adapter": "^1.6.14",
    "@better-auth/expo": "^1.6.14",
    "@hocuspocus/extension-database": "^4.3.0",
    "@hocuspocus/server": "^4.3.0",
    "@hocuspocus/transformer": "^4.3.0",
    "@notelab/connectors": "file:../../packages/connectors",
    "@notelab/features": "file:../../packages/features",
    "@tiptap/pm": "^3.23.6",
    "ai": "^6.0.193",
    "better-auth": "^1.6.14",
    "crossws": "^0.4.9",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.22",
    "pg": "^8.21.0",
    "yjs": "^13.6.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
