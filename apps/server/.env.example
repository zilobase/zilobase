DATABASE_URL=postgres://YOUR_LOCAL_POSTGRES_USER:YOUR_LOCAL_POSTGRES_PASSWORD@localhost:5432/zilobase
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000
CLIENT_URL=http://localhost:1420,http://localhost:4173
# Optional; defaults to BETTER_AUTH_SECRET when omitted.
COLLABORATION_SECRET=
COLLABORATION_WEBSOCKET_URL=ws://localhost:3000/collaboration
# Optional for alternate dev ports:
# CLIENT_URL=http://localhost:1420,http://localhost:4173,http://localhost:1422

# Optional SMTP delivery. Without SMTP_HOST, auth emails are printed to logs.
EMAIL_FROM=Zilobase <hello@example.com>
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=

# Image uploads
# Use "s3" locally to exercise S3-compatible presigned URLs.
IMAGE_STORAGE_MODE=s3
OPENAI_API_KEY=
TOOLKIT_API_KEY=
# Optional local/self-hosted override; defaults to https://api.toolkit-sdk.dev.
TOOLKIT_BASE_URL=
IMAGE_UPLOAD_MAX_BYTES=10485760
IMAGE_UPLOAD_URL_TTL_SECONDS=600
IMAGE_READ_URL_TTL_SECONDS=300
S3_BUCKET_NAME=zilobase-images
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
