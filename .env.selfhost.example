# Copy this file to .env before running a public self-hosted deployment.
# The docker-compose.yml file includes localhost defaults for evaluation, but
# production deployments should set every secret below.
# If you already booted the stack once without this file, either keep the
# original default database/object-store passwords here or recreate the Docker
# volumes with `docker compose down -v` before starting again.

# Caddy site address. Use http://localhost for local-only testing, or a real
# domain for automatic HTTPS.
ZILOBASE_SITE_ADDRESS=notes.example.com
CLIENT_URL=https://notes.example.com
BETTER_AUTH_URL=https://notes.example.com

# Generate strong values, for example:
# openssl rand -base64 48
BETTER_AUTH_SECRET=replace-with-a-random-secret

# Postgres
POSTGRES_DB=zilobase
POSTGRES_USER=zilobase
POSTGRES_PASSWORD=replace-with-a-random-password

# MinIO object storage
MINIO_BUCKET=zilobase
MINIO_ROOT_USER=zilobase
MINIO_ROOT_PASSWORD=replace-with-a-random-minio-password

# SMTP email delivery. Cloudflare Email Service uses smtp.mx.cloudflare.net,
# port 465, implicit TLS, username api_token, and an Email Sending: Edit API
# token as the password. Other SMTP providers can use their own settings.
EMAIL_FROM=Zilobase <hello@example.com>
SMTP_HOST=smtp.mx.cloudflare.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=api_token
SMTP_PASSWORD=replace-with-a-cloudflare-email-sending-api-token

# Optional AI support.
OPENAI_API_KEY=
TOOLKIT_API_KEY=
# Optional self-hosted Toolkit API URL; hosted Toolkit is used when omitted.
TOOLKIT_BASE_URL=
